server:
  port: 8191
  mode: debug

database:
  dsn: "host=postgres user=postgres password=dev dbname=drop port=5432 sslmode=disable"
  max_open_conns: 100
  max_idle_conns: 10

grpc:
  drop_server_addr: "drop_server:50051"
  timeout_sec: 5

storage:
  endpoint: "minio:9000"
  access_key: "drop"
  secret_key: "dropdrop"
  bucket: "drop"
  use_ssl: false
  presign_ttl_sec: 3600

log:
  level: "info"
